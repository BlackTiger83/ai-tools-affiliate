---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Affiliate Disclosure" description="Affiliate disclosure for AI Tools Lab.">
  <main class="content">
    <span class="badge">DISCLOSURE</span>
    <h1>Affiliate disclosure</h1>
    <p>This site may contain affiliate links in the future. If you buy through those links, we may earn a commission at no extra cost to you.</p>
    <p>Our recommendations must be based on research criteria, source-backed claims, and clear fit or bad-fit guidance. Affiliate potential is not allowed to replace editorial judgment.</p>
    <p>This project is currently prelaunch. Public indexing is intentionally blocked.</p>
  </main>
</BaseLayout>
